# Example environment file for ordermanager backend
# Copy this to ".env" and fill in real values before running locally.

# MongoDB Atlas connection string (use a full URI)
MONGODB_URI=

# Secret used to sign JWT tokens. Keep this value private.
JWT_SECRET=

# Email transport configuration. Provide either SMTP_URL or Gmail credentials.
SMTP_URL=
GMAIL_USER=
GMAIL_PASS=

# Address used as the "from" field when sending emails
EMAIL_FROM=

# Origin allowed for CORS (frontend URL)
CLIENT_ORIGIN=

# Port on which the server listens (render provides its own)
PORT=