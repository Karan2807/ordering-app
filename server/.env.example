# Example environment for the backend server
# Copy to ".env" and fill in values before starting the backend locally or on Render.

PORT=5000
MONGODB_URI=
JWT_SECRET=your-secret-here

# optional: origin URL(s) for the frontend application (used by CORS)
# you can specify a single host or a comma-separated list.  examples:
#   CLIENT_ORIGIN=https://ordering-app-uu24.onrender.com
#   CLIENT_ORIGIN=https://ordering-app-uu24.onrender.com,https://apnabazarstoresordering.com
# when deploying the frontend to a custom domain you must include that domain
# here so the backend will accept its requests.

# SMTP transport, email settings, etc. (see README for details)
